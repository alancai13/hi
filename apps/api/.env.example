# apps/api/.env.example
# Copy to .env — never commit the real .env file.

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─── Gemini / AI ──────────────────────────────────────────────────────────────
# Backend: "gemini_api" (API key) or "vertex" (service account / ADC)
GEMINI_BACKEND=gemini_api

# Google AI Studio API key  (AIzaSy... format)
# Get one at: https://aistudio.google.com/app/apikey
# IMPORTANT: never commit this value
GEMINI_API_KEY=your-api-key-here

# Model to use — gemini-2.0-flash is fast and good at code generation
GEMINI_MODEL=gemini-2.0-flash

# Vertex AI (alternative to API key — requires GCP service account)
# GEMINI_BACKEND=vertex
# GCP_PROJECT=your-project-id
# GCP_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Playwright ───────────────────────────────────────────────────────────────
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_HEADLESS=true

# ─── Persistence (future) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/testgen
# REDIS_URL=redis://localhost:6379/0
